# Скопируйте в .env и заполните реальными значениями. .env в .gitignore — не коммитить.

# --- Telegram ---
TELEGRAM_TOKEN=
TELEGRAM_CHAT_ID=

# --- AI ---
ANTHROPIC_API_KEY=
GROQ_API_KEY=

# --- Supabase (история сообщений) ---
SUPABASE_URL=
SUPABASE_KEY=

# --- Kwork мониторинг (Gmail IMAP) ---
GMAIL_USER=
GMAIL_APP_PASSWORD=

# --- Голосовые ответы (Yandex SpeechKit), опционально ---
VOICE_REPLY_ENABLED=true
YANDEX_API_KEY=
YANDEX_FOLDER_ID=

# --- HTTP API для voice-core (вход в бота), см. index.js api.post('/api/ask') ---
VOICE_API_TOKEN=
PORT=3000

# --- Dashboard API (мониторинг агентов для внешнего веб/PWA дашборда) ---
# Роуты /api/system и /api/agents* живут на том же порту PORT, что и /api/ask
# выше — отдельный порт им не нужен (Railway пробрасывает наружу один порт
# на публичный домен сервиса).
# Сгенерировать случайную строку, например: openssl rand -hex 32
# Такое же значение прописать в Railway → Variables → DASHBOARD_API_TOKEN
DASHBOARD_API_TOKEN=
